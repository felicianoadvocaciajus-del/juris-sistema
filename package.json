{
  "name": "juris-sistema",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema interno para escritorio de advocacia",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "db:generate": "npm run db:generate -w apps/api",
    "db:push": "npm run db:push -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:studio": "npm run db:studio -w apps/api",
    "backup": "bash infra/scripts/backup.sh",
    "restore": "bash infra/scripts/restore.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint": "concurrently \"npm run lint -w apps/api\" \"npm run lint -w apps/web\"",
    "test": "npm run test -w apps/api",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174"
  }
}
