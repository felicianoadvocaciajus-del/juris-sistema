# ===========================================
# JurisSystem - Configuracao de Ambiente
# ===========================================
# Copie este arquivo para .env e ajuste os valores

# Banco de Dados PostgreSQL
POSTGRES_DB=juris
POSTGRES_USER=juris
POSTGRES_PASSWORD=juris_secret_2024
POSTGRES_PORT=5432
DATABASE_URL=postgresql://juris:juris_secret_2024@localhost:5432/juris

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# API (NestJS)
API_PORT=4000
API_URL=http://localhost:4000

# Frontend (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# JWT / Autenticacao
JWT_SECRET=juris-jwt-secret-trocar-em-producao-2024
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=juris-refresh-secret-trocar-em-producao-2024
JWT_REFRESH_EXPIRES_IN=7d

# Storage de Documentos
# Pasta raiz onde o escritorio guarda documentos de clientes
DOCUMENTS_ROOT_PATH=C:\Documentos\Clientes
# Pasta para uploads diretos ao sistema
UPLOADS_PATH=./data/uploads
# Tamanho maximo de upload em MB
MAX_UPLOAD_SIZE_MB=50

# Backup
BACKUP_PATH=./infra/backups
BACKUP_RETENTION_DAYS=30

# Ambiente
NODE_ENV=development
